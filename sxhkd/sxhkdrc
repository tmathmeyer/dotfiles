# Reload functions
super + Escape
	pkill -USR1 -x sxhkd

super + t
    gnome-terminal

ctrl + alt + c
    google-chrome

ctrl + alt + s
    sublime_text

ctrl + alt + l
    robolock -c "#FF00FF"

ctrl + alt + p
    fcmd.py 40x2 prodaccess

ctrl + alt + h
    fcmd.py 80x40 htop

~button1
    bspc pointer -g focus

ctrl + alt + r
    bspc node @/ -R 90

ctrl + alt + {Left,Right}
    bspc desktop -f {prev,next}

ctrl + alt + w
    bspc node -c

alt + space
    exec dmscript

super + space
    bspc node -t ~floating

super + {_,shift + }{1-9,0}
    bspc {desktop -f,node -d} ^{1-9,10}
